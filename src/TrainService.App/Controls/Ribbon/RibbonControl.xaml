<UserControl x:Class="TrainService.App.Controls.Ribbon.RibbonControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:ribbon="clr-namespace:TrainService.App.Controls.Ribbon"
             Height="96"
             Background="#2A2A2A">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="28"/>
            <RowDefinition Height="28"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Quick Access Toolbar -->
        <Border Grid.Row="0" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="8,0,0,0"
                        x:Name="QuickAccessPanel">
            </StackPanel>
        </Border>

        <!-- Row 1: Tab Headers -->
        <WrapPanel Grid.Row="1" Background="#252525" Margin="4,0,0,0"
                   x:Name="TabHeaderPanel">
        </WrapPanel>

        <!-- Row 2: Tab Content (groups + items) -->
        <Border Grid.Row="2" Background="#2A2A2A" BorderBrush="#333333" BorderThickness="0,1,0,0"
                x:Name="TabContentBorder">
            <StackPanel Orientation="Horizontal" Margin="8,4,0,0"
                        x:Name="TabContentPanel">
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
