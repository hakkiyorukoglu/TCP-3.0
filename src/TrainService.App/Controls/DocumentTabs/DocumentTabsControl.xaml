<UserControl x:Class="TrainService.App.Controls.DocumentTabs.DocumentTabsControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="clr-namespace:TrainService.App.Models"
      Height="32">

    <Border Background="#252525" BorderBrush="#333333" BorderThickness="0,0,0,1">
        <DockPanel VerticalAlignment="Stretch">
            <!-- + Butonu -->
            <Button DockPanel.Dock="Left" Content="+" Width="28" Height="28"
                    Margin="4,2,2,2" Padding="0"
                    Command="{Binding AddTabCommand}"
                    Background="Transparent" Foreground="#CCC"
                    BorderBrush="#444" BorderThickness="1"
                    FontSize="14" FontWeight="Bold"
                    ToolTip="Yeni sekme"/>

            <!-- Sekme Listesi -->
            <ItemsControl DockPanel.Dock="Left" ItemsSource="{Binding Tabs}" Margin="2,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:EditorTabModel}">
                        <Border Padding="10,4" Margin="1,0,1,0"
                                Background="#333333"
                                BorderBrush="#444444" BorderThickness="1,1,1,0"
                                CornerRadius="4,4,0,0"
                                Cursor="Hand">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDirty}" Value="True">
                                            <Setter Property="Background" Value="#3a3a2a"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding DisplayName}" 
                                           Foreground="#CCCCCC" FontSize="12"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" ★" Foreground="Orange" FontSize="10"
                                           Visibility="{Binding IsDirty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                <!-- Kapatma Butonu -->
                                <Button Content="×" Width="16" Height="16"
                                        Margin="6,0,0,0" Padding="0"
                                        Command="{Binding DataContext.CloseTabCommand, 
                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        Background="Transparent" Foreground="#888"
                                        BorderThickness="0" FontSize="11"
                                        ToolTip="Sekmeyi kapat"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>
    </Border>
</UserControl>