<UserControl x:Class="TrainService.App.Controls.FeatureTree.FeatureTreeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ft="clr-namespace:TrainService.Cad.FeatureTree;assembly=TrainService.Cad">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid>
        <TreeView x:Name="FeatureTreeView"
                  ItemsSource="{Binding Roots}"
                  Background="#1E1E1E"
                  BorderThickness="0"
                  Foreground="White"
                  FontFamily="Segoe UI"
                  FontSize="13"
                  SelectedItemChanged="OnTreeViewSelectedItemChanged"
                  MouseDoubleClick="OnTreeViewDoubleClick">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate DataType="{x:Type ft:FeatureTreeItem}"
                                          ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <!-- İkon -->
                        <TextBlock Text="{Binding Icon}" 
                                   Margin="0,0,4,0" 
                                   VerticalAlignment="Center"
                                   FontSize="14"/>
                        
                        <!-- İsim -->
                        <TextBlock Text="{Binding Name}" 
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Width="110">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="White"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Foreground" Value="DeepSkyBlue"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                            <Setter Property="Opacity" Value="0.4"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        
                        <!-- 👁 Göz simgesi (tıklanabilir) -->
                        <Button Content="{Binding EyeIcon}"
                                Click="OnToggleVisibilityClick"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#888"
                                Width="20" Height="20"
                                Padding="0"
                                Margin="2,0,0,0"
                                ToolTip="Göster/Gizle"
                                FontSize="11"/>
                        
                        <!-- 🔒 Kilit simgesi (tıklanabilir) -->
                        <Button Content="🔒"
                                Click="OnToggleLockClick"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="#888"
                                Width="20" Height="20"
                                Padding="0"
                                Margin="2,0,0,0"
                                ToolTip="Kilitle/Kilidi Aç"
                                FontSize="11"
                                Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
