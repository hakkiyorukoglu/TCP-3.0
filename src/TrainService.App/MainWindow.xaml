<ui:FluentWindow x:Class="TrainService.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:pages="clr-namespace:TrainService.App.Views.Pages"
        Title="{Binding ViewModel.ApplicationTitle}" Height="600" Width="900"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="{Binding ViewModel.ApplicationTitle}" Grid.Row="0" />
        
        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           PaneDisplayMode="Left">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Home" Icon="{ui:SymbolIcon Home24}" TargetPageType="{x:Type pages:HomeView}" />
                <ui:NavigationViewItem Content="Editor" Icon="{ui:SymbolIcon Edit24}" TargetPageType="{x:Type pages:EditorView}" />
                <ui:NavigationViewItem Content="Electronics" Icon="{ui:SymbolIcon DeveloperBoard24}" TargetPageType="{x:Type pages:ElectronicsView}" />
                <ui:NavigationViewItem Content="Kitchen" Icon="{ui:SymbolIcon Food24}" TargetPageType="{x:Type pages:KitchenView}" />
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
                <ui:NavigationViewItem Content="Info" Icon="{ui:SymbolIcon Info24}" TargetPageType="{x:Type pages:InfoView}" />
                <ui:NavigationViewItem Content="Settings" Icon="{ui:SymbolIcon Settings24}" TargetPageType="{x:Type pages:SettingsView}" />
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>
    </Grid>
</ui:FluentWindow>
