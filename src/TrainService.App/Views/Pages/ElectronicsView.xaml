<Page x:Class="TrainService.App.Views.Pages.ElectronicsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:models="clr-namespace:TrainService.App.Models"
      Title="Electronics">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Network Topology (Node-Based)" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ui:Button Content="Add Entity" Icon="Add24" Command="{Binding ViewModel.OpenAddDrawerCommand}" HorizontalAlignment="Right" Appearance="Primary" />
            </DockPanel>

            <Border Grid.Row="1" Grid.RowSpan="3" Background="#1E1E1E" CornerRadius="8" BorderBrush="#333" BorderThickness="1" ClipToBounds="True">
                <ItemsControl ItemsSource="{Binding ViewModel.CanvasNodes}">
                    
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas IsItemsHost="True" Background="Transparent" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>

                    <ItemsControl.Resources>
                        <!-- SwitchNodeItem Template -->
                        <DataTemplate DataType="{x:Type models:SwitchNodeItem}">
                            <Border Width="160" Background="#2D2D30" BorderBrush="#007ACC" BorderThickness="2" CornerRadius="6" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="White" />
                                    <TextBlock Text="Network Switch" FontSize="10" Foreground="LightGray" />
                                    <TextBlock Text="{Binding SwitchEntity.PortCount, StringFormat='{}Ports: {0}'}" FontSize="10" Foreground="Gray" Margin="0,5,0,0" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                        
                        <!-- DeviceNodeItem Template -->
                        <DataTemplate DataType="{x:Type models:DeviceNodeItem}">
                            <Border Width="130" Background="#252526" BorderBrush="#009688" BorderThickness="2" CornerRadius="6" Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    
                                    <!-- Health LED -->
                                    <Ellipse Width="10" Height="10" Fill="{Binding HealthColor}" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                             ToolTip="{Binding LastSeenText}" Margin="0,-5,-5,0" />
                                    
                                    <TextBlock Grid.Row="0" Text="{Binding Name}" FontWeight="Bold" Foreground="White" Margin="0,0,15,0" />
                                    <TextBlock Grid.Row="1" Text="{Binding DeviceEntity.Kind}" FontSize="10" Foreground="#009688" />
                                    <TextBlock Grid.Row="2" Text="{Binding IpAddress}" FontSize="10" Foreground="Gray" Margin="0,5,0,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.Resources>
                </ItemsControl>
            </Border>
        </Grid>

        <!-- Right Panel (Drawer) -->
        <Border Grid.Column="1" Width="300" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1,0,0,0"
                Visibility="{Binding ViewModel.IsDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Margin="15">
                <TextBlock Text="Add New Entity" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20" />

                <TextBlock Text="Entity Type" Margin="0,0,0,5" />
                <ComboBox SelectedIndex="{Binding ViewModel.NewEntityTypeIndex}" Margin="0,0,0,15">
                    <ComboBoxItem Content="Network Switch" />
                    <ComboBoxItem Content="PC / Server" />
                    <ComboBoxItem Content="Station ESP32" />
                    <ComboBoxItem Content="Train ESP32" />
                </ComboBox>

                <TextBlock Text="Name" Margin="0,0,0,5" />
                <ui:TextBox Text="{Binding ViewModel.NewEntityName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" />

                <!-- IP / MAC (Only for Devices) -->
                <TextBlock Text="IP Address" Margin="0,0,0,5" />
                <ui:TextBox Text="{Binding ViewModel.NewEntityIp, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" />

                <TextBlock Text="MAC Address" Margin="0,0,0,5" />
                <ui:TextBox Text="{Binding ViewModel.NewEntityMac, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" />

                <!-- Port Count (Only for Switches) -->
                <TextBlock Text="Port Count (For Switch Only)" Margin="0,0,0,5" />
                <ui:TextBox Text="{Binding ViewModel.NewSwitchPortCount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="Cancel" Command="{Binding ViewModel.OpenAddDrawerCommand}" Appearance="Secondary" Margin="0,0,10,0" 
                               CommandParameter="Cancel" />
                    <ui:Button Content="Save" Command="{Binding ViewModel.SaveNewEntityCommand}" Appearance="Primary" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
