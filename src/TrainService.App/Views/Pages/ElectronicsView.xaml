<Page x:Class="TrainService.App.Views.Pages.ElectronicsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Electronics">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="Network Switches" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ui:Button Content="Add Entity" Icon="Add24" Command="{Binding ViewModel.OpenAddDrawerCommand}" HorizontalAlignment="Right" Appearance="Primary" />
            </DockPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding ViewModel.Switches}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Port Count" Binding="{Binding PortCount}" Width="100" />
                    <DataGridTemplateColumn Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ui:Button Icon="Delete24" Command="{Binding DataContext.ViewModel.DeleteSwitchCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Appearance="Danger" Padding="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="2" Text="Devices" FontSize="20" FontWeight="SemiBold" Margin="0,20,0,10" />

            <DataGrid Grid.Row="3" ItemsSource="{Binding ViewModel.Devices}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Kind}" Width="120" />
                    <DataGridTextColumn Header="IP Address" Binding="{Binding Ip}" Width="120" />
                    <DataGridTextColumn Header="MAC" Binding="{Binding Mac}" Width="150" />
                    <DataGridTemplateColumn Width="70">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ui:Button Icon="Delete24" Command="{Binding DataContext.ViewModel.DeleteDeviceCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Appearance="Danger" Padding="5,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Right Panel (Drawer) -->
        <Border Grid.Column="1" Width="300" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}" 
                BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}" BorderThickness="1,0,0,0"
                Visibility="{Binding ViewModel.IsDrawerOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Margin="15">
                <TextBlock Text="Add New Entity" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20" />

                <TextBlock Text="Entity Type" Margin="0,0,0,5" />
                <ComboBox SelectedIndex="{Binding ViewModel.NewEntityTypeIndex}" Margin="0,0,0,15">
                    <ComboBoxItem Content="Network Switch" />
                    <ComboBoxItem Content="PC / Server" />
                    <ComboBoxItem Content="Station ESP32" />
                    <ComboBoxItem Content="Train ESP32" />
                </ComboBox>

                <TextBlock Text="Name" Margin="0,0,0,5" />
                <ui:TextBox Text="{Binding ViewModel.NewEntityName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" />

                <!-- IP / MAC (Only for Devices) -->
                <TextBlock Text="IP Address" Margin="0,0,0,5" />
                <ui:TextBox Text="{Binding ViewModel.NewEntityIp, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" />

                <TextBlock Text="MAC Address" Margin="0,0,0,5" />
                <ui:TextBox Text="{Binding ViewModel.NewEntityMac, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" />

                <!-- Port Count (Only for Switches) -->
                <TextBlock Text="Port Count (For Switch Only)" Margin="0,0,0,5" />
                <ui:TextBox Text="{Binding ViewModel.NewSwitchPortCount, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20" />

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button Content="Cancel" Command="{Binding ViewModel.OpenAddDrawerCommand}" Appearance="Secondary" Margin="0,0,10,0" 
                               CommandParameter="Cancel" />
                    <ui:Button Content="Save" Command="{Binding ViewModel.SaveNewEntityCommand}" Appearance="Primary" />
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Page>
