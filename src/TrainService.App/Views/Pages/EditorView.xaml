<Page x:Class="TrainService.App.Views.Pages.EditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:ribbon="clr-namespace:TrainService.App.Controls.Ribbon"
      xmlns:cad="clr-namespace:TrainService.App.Controls.CadCanvas"
      xmlns:ft="clr-namespace:TrainService.App.Controls.FeatureTree"
      xmlns:docTabs="clr-namespace:TrainService.App.Controls.DocumentTabs"
      xmlns:term="clr-namespace:TrainService.App.Controls"
      xmlns:props="clr-namespace:TrainService.App.Controls.PropertiesPanel"
      Title="Editor">

    <Page.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding ViewModel.UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding ViewModel.RedoCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding ViewModel.SaveCommand}" />
        <KeyBinding Key="F9" Command="{Binding ViewModel.ToggleSnapCommand}" />
        <KeyBinding Key="Z" Modifiers="Control+Shift" Command="{Binding ViewModel.ZoomExtentsCommand}" />
        <KeyBinding Key="W" Command="{Binding ViewModel.ZoomWindowCommand}" />
        <KeyBinding Key="C" Modifiers="Control" Command="{Binding ViewModel.CopyCommand}" />
        <KeyBinding Key="X" Modifiers="Control" Command="{Binding ViewModel.CutCommand}" />
        <KeyBinding Key="V" Modifiers="Control" Command="{Binding ViewModel.PasteCommand}" />
    </Page.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Ribbon -->
        <ribbon:RibbonControl Grid.Row="0"
                               x:Name="RibbonCtrl"
                               Tabs="{Binding ViewModel.RibbonTabs}"
                               QuickAccessItems="{Binding ViewModel.RibbonQuickAccess}"
                               ViewModel="{Binding ViewModel}"/>

        <!-- Sekme Şeridi -->
        <docTabs:DocumentTabsControl Grid.Row="1" x:Name="TabStrip"
            DataContext="{Binding TabsViewModel}"/>

        <!-- Content Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- Sol Panel: Feature Tree -->
            <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#333333" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="8,6" Background="#252525" BorderBrush="#333333" BorderThickness="0,0,0,1">
                        <TextBlock Text="Öğe Ağacı" FontWeight="Bold" Foreground="#CCCCCC" FontSize="13"/>
                    </Border>

                    <ft:FeatureTreeControl x:Name="FeatureTreeCtrl" Grid.Row="1"/>
                </Grid>
            </Border>

            <!-- Orta: Viewport -->
            <Grid Grid.Column="1">
                <cad:CadViewportControl x:Name="Viewport"/>

                <!-- Zoom Kontrol Paneli -->
                <Border Panel.ZIndex="999" HorizontalAlignment="Left" VerticalAlignment="Bottom"
                        Margin="10,0,0,10" Padding="6"
                        Background="#EE1E1E1E" CornerRadius="6"
                        BorderBrush="#55FFFFFF" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="−" Width="24" Height="24"
                                Background="Transparent" Foreground="#CCC"
                                BorderBrush="#555" BorderThickness="1"
                                Click="OnZoomOutClick"/>
                        <Slider x:Name="ZoomSlider" Width="100"
                                Minimum="1" Maximum="10000" 
                                Value="{Binding ViewModel.ZoomScale}"
                                Margin="4,0"/>
                        <Button Content="+" Width="24" Height="24"
                                Background="Transparent" Foreground="#CCC"
                                BorderBrush="#555" BorderThickness="1"
                                Click="OnZoomInClick"/>
                        <TextBlock x:Name="ZoomPercent" 
                                   Text="{Binding ViewModel.ZoomPercentText}"
                                   FontFamily="Consolas" FontSize="12"
                                   Foreground="#CCC" Margin="6,0,0,0"
                                   VerticalAlignment="Center" Width="40"/>
                        <Button Content="Fit" Width="32" Height="24"
                                Margin="4,0,0,0"
                                Background="Transparent" Foreground="#CCC"
                                BorderBrush="#555" BorderThickness="1"
                                Command="{Binding ViewModel.ZoomExtentsCommand}"/>
                    </StackPanel>
                </Border>

                <!-- Koordinat ve FPS Paneli -->
                <Border Panel.ZIndex="999" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="10,0,10,10" Padding="8"
                        Background="#EE1E1E1E" CornerRadius="6"
                        BorderBrush="#55FFFFFF" BorderThickness="1" IsHitTestVisible="False">
                    <StackPanel Orientation="Vertical">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                            <ui:SymbolIcon Symbol="TargetArrow24" Foreground="DeepSkyBlue" Margin="0,0,5,0"/>
                            <TextBlock x:Name="LblCoordinates" Text="X: 0.0 Y: 0.0 mm" FontFamily="Consolas" FontSize="14" Foreground="White" FontWeight="Bold"/>
                            <TextBlock x:Name="LblSnapStatus" Text="{Binding ViewModel.SnapStatusText}" FontFamily="Consolas" FontSize="14" Foreground="{Binding ViewModel.SnapStatusColor}" FontWeight="Bold" Visibility="Visible"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Video24" Foreground="LimeGreen" Margin="0,0,5,0"/>
                            <TextBlock x:Name="LblFps" Text="FPS: 0" FontFamily="Consolas" FontSize="14" Foreground="LimeGreen" FontWeight="Bold" Margin="0,0,15,0"/>
                            <ui:SymbolIcon Symbol="Document24" Foreground="LightGray" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding ViewModel.DocumentStatusText}" FontFamily="Consolas" FontSize="14" Foreground="LightGray" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <ui:SymbolIcon Symbol="Layer24" Foreground="HotPink" Margin="0,0,5,0"/>
                            <TextBlock Text="{Binding ViewModel.ActiveLayerStatusText}" FontFamily="Consolas" FontSize="14" Foreground="HotPink" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Sağ Panel: Properties -->
            <props:PropertiesPanelControl Grid.Column="2" x:Name="PropertiesPanel"/>
        </Grid>

        <!-- Terminal Panel -->
        <term:TerminalPanel Grid.Row="3" 
            DataContext="{Binding ViewModel.TerminalViewModel}"
            BorderBrush="#333333" BorderThickness="0,1,0,0"/>
    </Grid>
</Page>