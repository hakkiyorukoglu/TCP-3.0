<Page x:Class="TrainService.App.Views.Pages.EditorView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:TrainService.App.Controls"
      xmlns:cad="clr-namespace:TrainService.App.Controls.CadCanvas"
      Title="Editor">
      
    <Page.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding ViewModel.UndoCommand}" />
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding ViewModel.RedoCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding ViewModel.SaveCommand}" />
        <KeyBinding Key="F9" Command="{Binding ViewModel.ToggleSnapCommand}" />
    </Page.InputBindings>
    
    <Grid>
        <cad:CadViewportControl x:Name="Viewport"/>
        
        <!-- Yüzen Koordinat ve FPS Paneli (Sol Üst Z-Index en üstte) -->
        <Border Panel.ZIndex="999" HorizontalAlignment="Left" VerticalAlignment="Top" 
                Margin="10" Padding="10" 
                Background="#EE1E1E1E" CornerRadius="6" 
                BorderBrush="#55FFFFFF" BorderThickness="1" IsHitTestVisible="False">
            <StackPanel Orientation="Vertical">
                <!-- Koordinat -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                    <ui:SymbolIcon Symbol="TargetArrow24" Foreground="DeepSkyBlue" Margin="0,0,5,0"/>
                    <TextBlock x:Name="LblCoordinates" Text="X: 0.0 Y: 0.0 mm" FontFamily="Consolas" FontSize="14" Foreground="White" FontWeight="Bold"/>
                    <TextBlock x:Name="LblSnapStatus" Text="{Binding ViewModel.SnapStatusText}" FontFamily="Consolas" FontSize="14" Foreground="Yellow" FontWeight="Bold" Visibility="Visible"/>
                </StackPanel>
                
                <!-- Durum Çubuğu ve FPS -->
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Video24" Foreground="LimeGreen" Margin="0,0,5,0"/>
                    <TextBlock x:Name="LblFps" Text="FPS: 0" FontFamily="Consolas" FontSize="14" Foreground="LimeGreen" FontWeight="Bold" Margin="0,0,15,0"/>
                    
                    <ui:SymbolIcon Symbol="Document24" Foreground="LightGray" Margin="0,0,5,0"/>
                    <TextBlock Text="{Binding ViewModel.DocumentStatusText}" FontFamily="Consolas" FontSize="14" Foreground="LightGray" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </Border>
        
        <!-- Toolbar -->
        <Border Panel.ZIndex="1000" HorizontalAlignment="Right" VerticalAlignment="Top" 
                Margin="10" Padding="5" Background="#EE1E1E1E" CornerRadius="6">
            <StackPanel Orientation="Horizontal">
                <ui:Button Command="{Binding ViewModel.SetToolCommand}" CommandParameter="Select"
                           Icon="SelectObject24" 
                           Appearance="Primary" ToolTip="Seç (S)" Margin="0,0,5,0" />
                <ui:Button Command="{Binding ViewModel.SetToolCommand}" CommandParameter="Track"
                           Icon="ArrowFlowUpRight24" 
                           Appearance="Primary" ToolTip="Ray (T)" Margin="0,0,5,0" />
                <ui:Button Command="{Binding ViewModel.SaveCommand}" 
                           Icon="Save24" 
                           Appearance="Secondary" ToolTip="Kaydet (Ctrl+S)" Margin="0,0,5,0" />
                <ui:Button Command="{Binding ViewModel.UndoCommand}" 
                           Icon="ArrowUndo24" 
                           Appearance="Secondary" ToolTip="Geri Al (Ctrl+Z)" Margin="0,0,5,0" />
                <ui:Button Command="{Binding ViewModel.RedoCommand}" 
                           Icon="ArrowRedo24" 
                           Appearance="Secondary" ToolTip="Yeniden Yap (Ctrl+Y)" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
