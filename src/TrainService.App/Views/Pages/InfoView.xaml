<Page x:Class="TrainService.App.Views.Pages.InfoView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:TrainService.Core.Enums;assembly=TrainService.Core"
             Title="Info">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Orientation="Horizontal" Margin="10">
            <TextBlock Text="Filtre: " VerticalAlignment="Center" Margin="0,0,5,0"/>
            <ComboBox ItemsSource="{Binding ViewModel.FilterOptions}" SelectedItem="{Binding ViewModel.SelectedFilter, Mode=TwoWay}" Width="150">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <ScrollViewer Grid.Row="1" Background="#1E1E1E">
            <ItemsControl ItemsSource="{Binding ViewModel.Logs}" Margin="10">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock FontFamily="Consolas" FontSize="14" Margin="0,2">
                            <Run Text="[" Foreground="Gray" />
                            <Run Text="{Binding Timestamp, StringFormat=yyyy-MM-dd HH:mm:ss.fff}" Foreground="Gray" />
                            <Run Text="]" Foreground="Gray" />
                            <Run Text=" [" Foreground="Gray" />
                            <Run Text="{Binding Source}" Foreground="Cyan" />
                            <Run Text="]" Foreground="Gray" />
                            <Run Text=" " />
                            <Run Text="{Binding Message}" x:Name="MsgRun" Foreground="#D4D4D4" />
                        </TextBlock>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Level}" Value="{x:Static core:LogLevel.Success}">
                                <Setter TargetName="MsgRun" Property="Foreground" Value="#4CAF50" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Level}" Value="{x:Static core:LogLevel.Warn}">
                                <Setter TargetName="MsgRun" Property="Foreground" Value="#FF9800" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Level}" Value="{x:Static core:LogLevel.Error}">
                                <Setter TargetName="MsgRun" Property="Foreground" Value="#F44336" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Level}" Value="{x:Static core:LogLevel.Info}">
                                <Setter TargetName="MsgRun" Property="Foreground" Value="#64B5F6" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
